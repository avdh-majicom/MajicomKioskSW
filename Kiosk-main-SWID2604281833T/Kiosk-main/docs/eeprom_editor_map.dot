digraph KioskEepromEditorMap {
  rankdir=TB;
  splines=ortho;
  nodesep=0.35;
  ranksep=0.45;
  node [shape=plain, fontname="Helvetica", fontsize=10];
  edge [fontname="Helvetica", fontsize=9];

  top [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_TOP</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">Top Menu<BR ALIGN="LEFT"/>- PCB HW ID<BR ALIGN="LEFT"/>- Water Disp Ctrl<BR ALIGN="LEFT"/>- Dispensed Units<BR ALIGN="LEFT"/>- KioskParm Edit<BR ALIGN="LEFT"/>- NFC Manage<BR ALIGN="LEFT"/>- Reinit</TD></TR></TABLE></TD></TR></TABLE>>];

  pcb [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_PCB</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">PCB HW ID<BR ALIGN="LEFT"/>Value:<BR ALIGN="LEFT"/>- HW ID (uint8)</TD></TR></TABLE></TD></TR></TABLE>>];
  wd_menu [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_WD_MENU</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">Water Disp Menu<BR ALIGN="LEFT"/>Fields:<BR ALIGN="LEFT"/>- Timed<BR ALIGN="LEFT"/>- Pulses<BR ALIGN="LEFT"/>- ModeSel (time/pulses)</TD></TR></TABLE></TD></TR></TABLE>>];
  wd_edit [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_WD_EDIT</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">Water Disp Edit<BR ALIGN="LEFT"/>Values:<BR ALIGN="LEFT"/>- Duration (100ms units)<BR ALIGN="LEFT"/>- Pulses<BR ALIGN="LEFT"/>- ModeSel (0=time,1=pulses)</TD></TR></TABLE></TD></TR></TABLE>>];

  disp_menu [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_DISPENSED_MENU</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">Dispensed Menu<BR ALIGN="LEFT"/>- App<BR ALIGN="LEFT"/>- Coin<BR ALIGN="LEFT"/>- NFC Token<BR ALIGN="LEFT"/>- Bypassed<BR ALIGN="LEFT"/>- TOTAL (read-only)</TD></TR></TABLE></TD></TR></TABLE>>];
  disp_edit [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_DISPENSED_EDIT</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">Dispensed Edit<BR ALIGN="LEFT"/>Value:<BR ALIGN="LEFT"/>- Counter (uint32)</TD></TR></TABLE></TD></TR></TABLE>>];

  kioskparm [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_KIOSKPARM_MENU</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">KioskParm Menu<BR ALIGN="LEFT"/>- Solenoid Config<BR ALIGN="LEFT"/>- KlaranUV Config<BR ALIGN="LEFT"/>- WaterTempSensor<BR ALIGN="LEFT"/>- Backwash Config<BR ALIGN="LEFT"/>- RTC Config<BR ALIGN="LEFT"/>- NFC Parms</TD></TR></TABLE></TD></TR></TABLE>>];

  sol_menu [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_SOL_MENU</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">Solenoid Menu<BR ALIGN="LEFT"/>- BackWashSol<BR ALIGN="LEFT"/>- WaterSenseBypSol<BR ALIGN="LEFT"/>- InletWaterSol<BR ALIGN="LEFT"/>- WaterDispSol</TD></TR></TABLE></TD></TR></TABLE>>];
  sol_edit [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_SOL_PARAM_EDIT</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">Solenoid Param Edit<BR ALIGN="LEFT"/>Params:<BR ALIGN="LEFT"/>- StartPWM<BR ALIGN="LEFT"/>- HoldPWM<BR ALIGN="LEFT"/>- SwOnDelay (sec)</TD></TR></TABLE></TD></TR></TABLE>>];

  bw_menu [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_BACKWASH_MENU</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">Backwash Menu<BR ALIGN="LEFT"/>- BW Duration (10s)<BR ALIGN="LEFT"/>- After N Disp<BR ALIGN="LEFT"/>- Dispense Count (uint16)<BR ALIGN="LEFT"/>- Daily Time (min since midnight)<BR ALIGN="LEFT"/>- Daily Dur (10s, 0=disabled)</TD></TR></TABLE></TD></TR></TABLE>>];
  bw_edit [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_BACKWASH_EDIT</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">Backwash Edit<BR ALIGN="LEFT"/>Edits selected field</TD></TR></TABLE></TD></TR></TABLE>>];
  bw_note [shape=note, label="Daily backwash applies only when RTC is present\l", labeljust="l"];

  uv_menu [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_KLARAN_MENU</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">KlaranUV Menu<BR ALIGN="LEFT"/>- UV OK Delay (10ms)<BR ALIGN="LEFT"/>- UV MAX ON time (min)</TD></TR></TABLE></TD></TR></TABLE>>];
  uv_edit [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_KLARAN_EDIT</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">KlaranUV Edit<BR ALIGN="LEFT"/>Edits selected field</TD></TR></TABLE></TD></TR></TABLE>>];

  wtemp [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_WATERTEMP_EDIT</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">WaterTempSensor<BR ALIGN="LEFT"/>Value:<BR ALIGN="LEFT"/>- T1 or T2</TD></TR></TABLE></TD></TR></TABLE>>];

  rtc [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_RTC_CONFIG</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">RTC Config<BR ALIGN="LEFT"/>- DS3231 presence<BR ALIGN="LEFT"/>- Date/Time edit (YYYY MM DD HH MM SS)<BR ALIGN="LEFT"/>- Not stored in EEPROM</TD></TR></TABLE></TD></TR></TABLE>>];

  nfc_parms_menu [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_NFC_PARMS_MENU</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">NFC Parms Menu<BR ALIGN="LEFT"/>- Init Delay (ms)<BR ALIGN="LEFT"/>- Scan Duration (ms)<BR ALIGN="LEFT"/>- Inter Delay (ms)</TD></TR></TABLE></TD></TR></TABLE>>];
  nfc_parms_edit [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_NFC_PARMS_EDIT</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">NFC Parms Edit<BR ALIGN="LEFT"/>Edits selected field</TD></TR></TABLE></TD></TR></TABLE>>];

  nfc_menu [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_NFC_MENU</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">NFC Menu<BR ALIGN="LEFT"/>- Browse/Delete<BR ALIGN="LEFT"/>- Add Token<BR ALIGN="LEFT"/>- Del Token<BR ALIGN="LEFT"/>- Pack NFC Table<BR ALIGN="LEFT"/>- Del ALL Tokens</TD></TR></TABLE></TD></TR></TABLE>>];
  nfc_browse [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_NFC_BROWSE</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">NFC Browse/Delete<BR ALIGN="LEFT"/>Value:<BR ALIGN="LEFT"/>- Token hash list</TD></TR></TABLE></TD></TR></TABLE>>];
  nfc_add [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_NFC_ADD</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">NFC Add Token<BR ALIGN="LEFT"/>- Scan token<BR ALIGN="LEFT"/>- Add if valid</TD></TR></TABLE></TD></TR></TABLE>>];
  nfc_del [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_NFC_DEL</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">NFC Del Token<BR ALIGN="LEFT"/>- Scan token<BR ALIGN="LEFT"/>- Delete if found</TD></TR></TABLE></TD></TR></TABLE>>];
  nfc_actions [shape=note, label="Pack/Remove-All are actions triggered from NFC Menu\l", labeljust="l"];

  reinit [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" ALIGN="LEFT"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">LAYER_REINIT</FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" ALIGN="LEFT"><TR><TD ALIGN="LEFT">Reinit<BR ALIGN="LEFT"/>- Reset EEPROM to defaults</TD></TR></TABLE></TD></TR></TABLE>>];

  { rank=same; wd_menu; wd_edit; }
  { rank=same; disp_menu; disp_edit; }
  { rank=same; kioskparm; sol_menu; sol_edit; }
  { rank=same; bw_menu; bw_edit; bw_note; }
  { rank=same; uv_menu; uv_edit; }
  { rank=same; nfc_parms_menu; nfc_parms_edit; }
  { rank=same; nfc_menu; nfc_browse; }

  top -> pcb -> wd_menu -> disp_menu -> kioskparm -> nfc_menu -> reinit;
  wd_menu -> wd_edit;
  disp_menu -> disp_edit;

  kioskparm -> sol_menu;
  sol_menu -> bw_menu -> uv_menu -> wtemp -> rtc -> nfc_parms_menu;
  sol_menu -> sol_edit;
  bw_menu -> bw_edit;
  bw_menu -> bw_note [style=dashed];
  uv_menu -> uv_edit;
  nfc_parms_menu -> nfc_parms_edit;

  nfc_menu -> nfc_browse;
  nfc_browse -> nfc_add -> nfc_del -> nfc_actions;
}
